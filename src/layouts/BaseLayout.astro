---
import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';

interface Props {
  title: string;
  description: string;
  path: string;
}

const site = 'https://www.hiharmonyos.com';
const { title, description, path } = Astro.props;
const canonical = new URL(path, site).toString();
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <SeoHead title={title} description={description} canonical={canonical} />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="container nav">
          <a class="brand" href="/">HiHarmonyOS</a>
          <nav>
            <a href="/">首页</a>
            <a href="/blog/">博客</a>
            <a href="/blog/archive/">归档</a>
            <a href="/blog/categories/">分类</a>
            <a href="/blog/tags/">标签</a>
            <a href="/rss.xml">RSS</a>
            <a href="/about/">关于</a>
          </nav>
        </div>
      </header>
      <main class="container">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="container footer-grid">
          <div>
            <strong>HiHarmonyOS</strong>
            <p>聚焦 HarmonyOS、ArkTS、鸿蒙应用工程化与 IT 极客实践。</p>
          </div>
          <div>
            <p>www.hiharmonyos.com</p>
            <p>GitHub + Vercel</p>
            <p><a href="/blog/archive/">浏览归档</a></p>
            <p><a href="/rss.xml">订阅 RSS</a></p>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
